APP_NAME="PortWatch AI"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-app.railway.app

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ── Database (Railway MySQL) ──────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=your-railway-mysql-host
DB_PORT=3306
DB_DATABASE=railway
DB_USERNAME=root
DB_PASSWORD=your-railway-mysql-password

# ── Session & Cache ───────────────────────────────────────────────────────────
# Use file driver on Railway to avoid database session bootstrap issues
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file

# ── Mail ──────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@portwatch.ai"
MAIL_FROM_NAME="${APP_NAME}"

# ── External APIs ─────────────────────────────────────────────────────────────
GNEWS_API_KEY=your-gnews-api-key
COUNTRY_API_KEY=your-country-api-key

VITE_APP_NAME="${APP_NAME}"
