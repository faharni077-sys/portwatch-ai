APP_NAME="PortWatch AI"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-app.railway.app

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ── Database (Railway MySQL) ──────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=
DB_PORT=3306
DB_DATABASE=railway
DB_USERNAME=root
DB_PASSWORD=

# ── Session ───────────────────────────────────────────────────────────────────
# Use "file" driver on Railway — avoids a chicken-and-egg problem where the
# sessions table may not exist yet when the first request comes in.
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Required on Railway (HTTPS) so the session cookie is flagged Secure.
# Without this, the browser drops the cookie and login sessions do not persist.
SESSION_SECURE_COOKIE=true

# ── Cache ─────────────────────────────────────────────────────────────────────
# Use "file" driver — no Redis or database needed on Railway.
CACHE_STORE=file

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

# ── Mail ──────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@portwatch.ai"
MAIL_FROM_NAME="${APP_NAME}"

# ── External APIs ─────────────────────────────────────────────────────────────
# GNews API key — required for News Intelligence feature
GNEWS_API_KEY=

VITE_APP_NAME="${APP_NAME}"
